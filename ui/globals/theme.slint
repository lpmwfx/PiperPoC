/// Theme colors for the PiperPoC application.
export global Theme {
    /// Background color for the main window.
    /// property `background`.
    in property <brush> background: #1e1e2e;
    /// Surface color for elevated elements.
    /// property `surface`.
    in property <brush> surface: #313244;
    /// Primary accent color.
    /// property `primary`.
    in property <brush> primary: #89b4fa;
    /// Secondary accent color for highlights.
    /// property `accent`.
    in property <brush> accent: #f38ba8;
    /// Primary text color.
    /// property `text-primary`.
    in property <brush> text-primary: #cdd6f4;
    /// Secondary text color for labels.
    /// property `text-secondary`.
    in property <brush> text-secondary: #a6adc8;
    /// Success state color.
    /// property `success`.
    in property <brush> success: #a6e3a1;
}
