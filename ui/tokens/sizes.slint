/// Design token sizes for layout spacing and dimensions.
export global Sizes {
    /// Extra-small spacing unit.
    in property <length> spacing-xs: 4px;
    /// Small spacing unit.
    in property <length> spacing-sm: 8px;
    /// Medium spacing unit (default).
    in property <length> spacing-md: 16px;
    /// Large spacing unit.
    in property <length> spacing-lg: 24px;
    /// Extra-large spacing unit.
    in property <length> spacing-xl: 32px;
    /// Default border radius for rounded elements.
    in property <length> border-radius: 8px;
    /// Standard height for input fields.
    in property <length> input-height: 40px;
}
